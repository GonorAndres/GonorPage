---
import BaseLayout from './BaseLayout.astro';
import type { Lang } from '../i18n';
import { t, useTranslatedPath } from '../i18n';
import CategoryBadge from '../components/ui/CategoryBadge.astro';
import Squiggle from '../components/decorations/Squiggle.astro';
import { getNoteBySlug, noteCategoryLabels, type NoteCategory } from '../data/notes';

interface Props {
  slug: string;
  lang: Lang;
}

const { slug, lang } = Astro.props;
const tp = useTranslatedPath(lang);
const note = getNoteBySlug(slug, lang);

if (!note) {
  return Astro.redirect(tp('/artifacts/'));
}

const categoryLabel = noteCategoryLabels[lang][note.category];
const formattedDate = new Date(note.createdDate + 'T12:00:00').toLocaleDateString(
  lang === 'es' ? 'es-MX' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);
const siteUrl = 'https://gonor.me';
const pageUrl = lang === 'es' ? `${siteUrl}/artifacts/${slug}/` : `${siteUrl}/en/artifacts/${slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  name: note.title,
  description: note.description,
  keywords: note.keywords,
  url: pageUrl,
  author: {
    '@type': 'Person',
    name: 'Andrés González Ortega',
    url: siteUrl,
  },
  educationalLevel: 'University',
  learningResourceType: 'Technical Note',
  inLanguage: lang,
};

const relatedNotes = note.relatedNotes
  ?.map((relSlug) => getNoteBySlug(relSlug, lang))
  .filter((n): n is NonNullable<typeof n> => n !== undefined) ?? [];

const driveFileMatch = note.urls.length === 1
  ? note.urls[0].url.match(/drive\.google\.com\/file\/d\/([^/]+)/)
  : null;
const previewUrl = driveFileMatch
  ? `https://drive.google.com/file/d/${driveFileMatch[1]}/preview`
  : undefined;
const previewLabel = lang === 'es' ? 'Vista previa del material' : 'Material preview';
const openPreviewLabel = lang === 'es' ? 'Abrir en Google Drive' : 'Open in Google Drive';
---

<BaseLayout
  title={`${note.title} | ${t(lang, 'notes.title')}`}
  description={note.description}
  lang={lang}
  ogType="article"
>
  <Fragment slot="head">
    <meta name="keywords" content={note.keywords.join(', ')} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <article class="py-10 sm:py-16 px-4 sm:px-6">
    <div class="max-w-2xl mx-auto">
      <div class="mb-8">
        <a href={tp('/artifacts/')} class="inline-flex items-center py-2 min-h-[40px] text-sm text-terracotta hover:underline mb-4">
          &larr; {t(lang, 'notes.backToNotes')}
        </a>
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <CategoryBadge label={categoryLabel} />
          <span class="text-xs text-navy/40">
            {t(lang, 'notes.created')}: {formattedDate}
          </span>
          <span class="text-xs px-2 py-0.5 rounded bg-amber/15 text-amber font-medium">
            v{note.version}
          </span>
        </div>
        <h1 class="text-3xl md:text-5xl font-bold text-navy leading-tight mb-4">{note.title}</h1>
      </div>
      <Squiggle class="w-full h-4 mb-8" color="#D4A574" />

      <div class="prose prose-lg max-w-none prose-p:text-navy/80 prose-p:leading-relaxed mb-8">
        <p>{note.description}</p>
      </div>

      {previewUrl && (
        <section class="mb-8" aria-labelledby="document-preview-title">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between mb-3">
            <h2 id="document-preview-title" class="font-serif text-xl font-bold text-navy">
              {previewLabel}
            </h2>
            <a
              href={note.urls[0].url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center min-h-[40px] text-sm text-terracotta hover:underline"
            >
              {openPreviewLabel} <span aria-hidden="true" class="ml-1">↗</span>
            </a>
          </div>
          <div class="overflow-hidden rounded-xl border border-amber/30 bg-white shadow-sm">
            <iframe
              src={previewUrl}
              title={`${previewLabel}: ${note.title}`}
              loading="lazy"
              class="block w-full h-[70svh] min-h-[32rem] sm:h-[44rem]"
            ></iframe>
          </div>
        </section>
      )}

      {/* Tags */}
      <div class="flex flex-wrap gap-2 mb-8">
        {note.tags.map((tag) => (
          <span class="text-xs px-3 py-1 rounded bg-sage/15 text-sage font-medium">{tag}</span>
        ))}
      </div>

      {/* Resource links — PDF download or artifact launch */}
      <div class="p-6 rounded-xl border border-amber/30 bg-amber/5 mb-8">
        <h2 class="font-serif text-lg font-bold text-navy mb-4">
          {note.type === 'artifact'
            ? (lang === 'es' ? 'Artefacto interactivo' : 'Interactive artifact')
            : t(lang, 'notes.downloadMaterial')}
        </h2>
        <div class="flex flex-wrap gap-4">
          {note.urls.map((link) => {
            const isInternal = link.url.startsWith('/');
            const href = isInternal
              ? `${link.url}${link.url.includes('?') ? '&' : '?'}lang=${lang}`
              : link.url;
            return (
              <a
                href={href}
                {...(!isInternal && { target: '_blank', rel: 'noopener noreferrer' })}
                class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-terracotta text-cream text-sm font-medium hover:bg-terracotta/90 transition-colors"
              >
                {isInternal ? (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                ) : (
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                )}
                {link.label}
              </a>
            );
          })}
        </div>
      </div>

      {/* Related notes */}
      {relatedNotes.length > 0 && (
        <div class="mt-12 pt-8 border-t border-amber/20">
          <h2 class="font-serif text-lg font-bold text-navy mb-4">{t(lang, 'notes.relatedNotes')}</h2>
          <div class="space-y-4">
            {relatedNotes.map((rel) => (
              <a
                href={lang === 'es' ? `/artifacts/${rel.slug}/` : `/en/artifacts/${rel.slug}/`}
                class="block p-4 rounded-xl border border-amber/20 hover:border-amber/40 hover:shadow-sm transition-all group"
              >
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs px-2 py-0.5 rounded bg-sage/15 text-sage font-medium">
                    {noteCategoryLabels[lang][rel.category]}
                  </span>
                </div>
                <h3 class="font-serif text-base font-bold text-navy group-hover:text-terracotta transition-colors">
                  {rel.title}
                </h3>
                <p class="text-sm text-navy/60 mt-1 line-clamp-2">{rel.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="mt-12 pt-8 border-t border-amber/20">
        <a href={tp('/artifacts/')} class="inline-flex items-center py-2 min-h-[40px] text-terracotta hover:underline text-sm">
          &larr; {t(lang, 'notes.backToNotes')}
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
