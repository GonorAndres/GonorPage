---
import type { Lang } from '../../i18n';
import { getFeedItems, kindLabel, type FeedKind } from '../../lib/feed';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const items = await getFeedItems(lang);
const latestKeys = new Set(items.slice(0, 3).map((i) => `${i.kind}:${i.slug}`));
const pool = items.filter((i) => !latestKeys.has(`${i.kind}:${i.slug}`));

for (let i = pool.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [pool[i], pool[j]] = [pool[j], pool[i]];
}

const discover = pool.slice(0, 3);

const KIND_ACCENT: Record<FeedKind, { border: string; chipBg: string; chipText: string }> = {
  blog: { border: 'border-l-terracotta', chipBg: 'bg-terracotta/12', chipText: 'text-terracotta' },
  artifact: { border: 'border-l-amber', chipBg: 'bg-amber/15', chipText: 'text-[#9a6a2a]' },
  note: { border: 'border-l-sage', chipBg: 'bg-sage/15', chipText: 'text-sage' },
};

function formatDate(date: string) {
  return new Date(date + 'T12:00:00').toLocaleDateString(lang === 'es' ? 'es-MX' : 'en-US', {
    month: 'short',
    day: 'numeric',
  });
}
---

{discover.map((item) => {
  const a = KIND_ACCENT[item.kind];
  return (
    <a
      href={item.href}
      class:list={[
        'flex flex-col gap-0.5 rounded-md border border-navy/8 bg-white/90 shadow-sm px-3 py-2 hover:shadow-md transition-all group flex-1 min-w-0',
      ]}
    >
      <div class="flex items-center gap-2">
        <span class:list={['text-[10px] px-1.5 py-0.5 rounded font-medium whitespace-nowrap uppercase tracking-wider', a.chipBg, a.chipText]}>
          {kindLabel(lang, item.kind)}
        </span>
        <time class="text-xs text-navy/50 ml-auto whitespace-nowrap">{formatDate(item.date)}</time>
      </div>
      <span class="font-serif text-xs font-bold text-navy leading-snug group-hover:text-terracotta transition-colors">
        {item.title}
      </span>
      <span class="text-[11px] text-navy/60 leading-snug line-clamp-2">
        {item.description}
      </span>
    </a>
  );
})}
