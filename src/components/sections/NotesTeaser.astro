---
import { t, useTranslatedPath } from '../../i18n';
import type { Lang } from '../../i18n';
import OrganicBlob from '../decorations/OrganicBlob.astro';
import Squiggle from '../decorations/Squiggle.astro';
import { getNotesByCategory } from '../../data/notes';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tp = useTranslatedPath(lang);

// Pick one note from each category (first from each group)
const groups = getNotesByCategory(lang);
const teaserNotes = groups.map((g) => ({
  ...g.notes[0],
  slug: g.notes[0].slug,
  categoryLabel: g.label,
}));
---

<section id="notas" class="relative py-14 sm:py-20 px-4 sm:px-6 overflow-hidden">
  <OrganicBlob variant={3} color="#D4A574" class="w-[250px] h-[250px] -top-10 -right-10 opacity-20" />

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="mb-8">
      <h2 class="text-3xl md:text-4xl font-bold text-navy fade-up">
        {t(lang, 'hero.featuredNotes')}
      </h2>
      <p class="text-navy/60 mt-2 fade-up">{t(lang, 'notes.subtitle')}</p>
      <Squiggle class="w-32 h-4 mt-2" color="#D4A574" />
    </div>

    <div class="md:ml-16 grid gap-6 md:grid-cols-3">
      {teaserNotes.map((note) => (
        <a
          href={lang === 'es' ? `/artifacts/${note.slug}/` : `/en/artifacts/${note.slug}/`}
          class="group p-5 rounded-xl border border-amber/20 hover:border-amber/50 hover:shadow-sm transition-all duration-300"
        >
          <span class="text-xs px-2 py-0.5 rounded bg-sage/15 text-sage font-medium">
            {note.categoryLabel}
          </span>
          <h3 class="font-serif text-base font-bold text-navy group-hover:text-terracotta transition-colors mt-3 mb-2 line-clamp-2">
            {note.title}
          </h3>
          <p class="text-sm text-navy/60 leading-relaxed line-clamp-3 mb-3">{note.description}</p>
          <div class="flex flex-wrap gap-1.5">
            {note.tags.slice(0, 3).map((tag) => (
              <span class="text-xs px-2 py-0.5 rounded bg-sage/20 text-sage">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <div class="md:ml-16 mt-8 text-center">
      <a
        href={tp('/artifacts/')}
        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-navy text-cream text-sm font-medium hover:bg-navy/90 transition-colors"
      >
        {t(lang, 'notes.seeAllNotes')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
