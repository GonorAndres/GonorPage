---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';
import OrganicBlob from '../decorations/OrganicBlob.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="contacto" class="relative py-20 px-6 overflow-hidden">
  <OrganicBlob variant={2} color="#D4A574" class="w-[400px] h-[400px] -top-20 -right-20 opacity-20" />

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="md:ml-12">
      <h2 class="text-3xl md:text-4xl font-bold text-navy mb-6 fade-up">
        {t(lang, 'section.contact')}
      </h2>
      <p class="text-navy/70 mb-8 fade-up">
        {t(lang, 'contact.message')}
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 fade-up">
        <a
          href="mailto:gonorandres@ciencias.unam.mx"
          class="flex items-center gap-3 p-4 rounded-xl border border-amber/20 hover:border-terracotta/40 hover:shadow-sm transition-all"
        >
          <span class="w-10 h-10 flex items-center justify-center rounded-full bg-navy/5">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </span>
          <div>
            <span class="font-medium text-navy">{t(lang, 'contact.email')}</span>
            <span class="block text-sm text-navy/50">gonorandres@ciencias.unam.mx</span>
          </div>
        </a>

        <a
          href="https://github.com/GonorAndres"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 rounded-xl border border-amber/20 hover:border-terracotta/40 hover:shadow-sm transition-all"
        >
          <span class="w-10 h-10 flex items-center justify-center rounded-full bg-navy/5">
            <svg class="w-5 h-5 text-navy" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </span>
          <div>
            <span class="font-medium text-navy">GitHub</span>
            <span class="block text-sm text-navy/50">GonorAndres</span>
          </div>
        </a>

        <a
          href="https://www.linkedin.com/in/andr%C3%A9s-g%C3%B3nzalez-ortega-190b49371/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 rounded-xl border border-amber/20 hover:border-terracotta/40 hover:shadow-sm transition-all"
        >
          <span class="w-10 h-10 flex items-center justify-center rounded-full bg-navy/5">
            <svg class="w-5 h-5 text-navy" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </span>
          <div>
            <span class="font-medium text-navy">LinkedIn</span>
            <span class="block text-sm text-navy/50">{lang === 'es' ? 'Perfil profesional' : 'Professional profile'}</span>
          </div>
        </a>

        <a
          href="/docs/cv-andres-gonzalez.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 rounded-xl border border-amber/20 hover:border-terracotta/40 hover:shadow-sm transition-all"
        >
          <span class="w-10 h-10 flex items-center justify-center rounded-full bg-navy/5">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          </span>
          <div>
            <span class="font-medium text-navy">CV</span>
            <span class="block text-sm text-navy/50">{lang === 'es' ? 'Descargar CV actualizado' : 'Download updated CV'}</span>
          </div>
        </a>

        <a
          href="https://drive.google.com/drive/folders/1fQXrnQaQckXr5nBcOWvSptJGdcixYVO8"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 rounded-xl border border-amber/20 hover:border-terracotta/40 hover:shadow-sm transition-all"
        >
          <span class="w-10 h-10 flex items-center justify-center rounded-full bg-navy/5">
            <svg class="w-5 h-5 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
          </span>
          <div>
            <span class="font-medium text-navy">Drive</span>
            <span class="block text-sm text-navy/50">{lang === 'es' ? 'Carpeta académica' : 'Academic folder'}</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { track, gaEvent } from '../../lib/analytics';

  const GA_EVENT: Record<string, string> = {
    cv: 'download_cv',
    correo: 'click_email',
    email: 'click_email',
    github: 'click_github',
    linkedin: 'click_linkedin',
  };

  document.querySelectorAll('#contacto a').forEach((link) => {
    link.addEventListener('click', () => {
      const label = link.querySelector('.font-medium')?.textContent?.trim() ?? 'unknown';
      const method = label.toLowerCase();
      track('contact_clicked', { method });
      const gaName = GA_EVENT[method];
      if (gaName) gaEvent(gaName, { source: 'contact' });
    });
  });
</script>
