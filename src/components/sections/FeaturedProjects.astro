---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';
import OrganicBlob from '../decorations/OrganicBlob.astro';
import Squiggle from '../decorations/Squiggle.astro';
import { getProjects, getRelatedProjectNames } from '../../data/projects';
import type { ProjectCategory } from '../../data/projects';
import ProjectsGrid from '../ui/ProjectsGrid';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const projects = getProjects(lang).map((p) => ({
  ...p,
  relatedNames: p.relatedTo ? getRelatedProjectNames(p.relatedTo, lang) : [],
  tier: p.tier,
  blogUrl: p.blogSlug
    ? (lang === 'en' ? `/en/blog/${p.blogSlug}/` : `/blog/${p.blogSlug}/`)
    : undefined,
}));

const labels = {
  viewProject: t(lang, 'projects.viewProject'),
  viewRepo: t(lang, 'projects.viewRepo'),
  viewDrive: t(lang, 'projects.viewDrive'),
  viewDetails: t(lang, 'projects.viewDetails'),
  viewLive: t(lang, 'projects.viewLive'),
  seeAlso: t(lang, 'projects.seeAlso'),
  inDevelopment: t(lang, 'projects.inDevelopment'),
  showAll: t(lang, 'projects.showAll'),
  showLess: t(lang, 'projects.showLess'),
  gridView: t(lang, 'projects.gridView'),
  listView: t(lang, 'projects.listView'),
  filterAll: t(lang, 'projects.filterAll'),
  sortTier: t(lang, 'projects.sortTier'),
  sortNewest: t(lang, 'projects.sortNewest'),
  sortOldest: t(lang, 'projects.sortOldest'),
  sortUpdated: t(lang, 'projects.sortUpdated'),
  sortLabel: t(lang, 'projects.sortLabel'),
  filterLabel: t(lang, 'projects.filterLabel'),
  categories: {
    'actuarial': t(lang, 'projects.actuarial'),
    'data-science': t(lang, 'projects.data-science'),
    'data-engineering': t(lang, 'projects.data-engineering'),
    'quant-finance': t(lang, 'projects.quant-finance'),
    'applied-math': t(lang, 'projects.applied-math'),
  } as Record<ProjectCategory, string>,
};
---

<section id="proyectos" class="relative py-20 px-6 overflow-hidden">
  <OrganicBlob variant={2} color="#C17654" class="w-[400px] h-[400px] -top-20 right-0 opacity-30" />

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="mb-14 md:ml-6">
      <h2 class="text-3xl md:text-4xl font-bold text-navy fade-up">
        {t(lang, 'section.featured')}
      </h2>
      <Squiggle class="w-32 h-4 mt-2" color="#C17654" />
    </div>

    <ProjectsGrid client:idle projects={projects} labels={labels} />
  </div>
</section>
