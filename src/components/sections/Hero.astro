---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';
import OrganicBlob from '../decorations/OrganicBlob.astro';
import LatestPostCard from '../ui/LatestPostCard.astro';
import DiscoverPostCard from '../ui/DiscoverPostCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="relative overflow-hidden py-10 md:py-12 px-6">
  <!-- Decorative blobs -->
  <OrganicBlob variant={1} color="#D4A574" class="w-[500px] h-[500px] -top-20 -right-40 opacity-60" />
  <OrganicBlob variant={3} color="#7A8B6F" class="w-[350px] h-[350px] bottom-0 -left-24 opacity-40" />

  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Asymmetric layout: text left, circle middle, blog card right -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
      <div class="md:col-span-7 md:col-start-1">
        <p class="text-sage font-medium text-lg mb-2 fade-up">
          {t(lang, 'hero.greeting')}
        </p>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-navy leading-tight mb-4 fade-up">
          <span class="block">Andrés</span>
          <span class="block">González Ortega</span>
        </h1>
        <p class="text-xl md:text-2xl text-terracotta font-serif mb-6 fade-up">
          {t(lang, 'hero.role')}
        </p>
        <p class="text-navy/70 text-lg max-w-lg mb-8 fade-up">
          {t(lang, 'hero.description')}
        </p>
        <div class="flex flex-wrap gap-4 fade-up">
          <a
            href="#proyectos"
            class="inline-block px-6 py-3 bg-terracotta text-cream font-medium rounded-lg hover:bg-terracotta/90 transition-colors"
          >
            {t(lang, 'hero.cta')}
          </a>
          <a
            href="/docs/cv-andres-gonzalez.pdf"
            target="_blank"
            rel="noopener noreferrer"
            data-cv-download
            class="inline-block px-6 py-3 border-2 border-navy/20 text-navy font-medium rounded-lg hover:border-terracotta hover:text-terracotta transition-colors"
          >
            {t(lang, 'hero.cv')}
          </a>
        </div>
      </div>

      <!-- Decorative circles (middle) -->
      <div class="hidden md:flex md:items-center md:justify-center md:col-span-2 md:col-start-8">
        <div class="relative">
          <div class="w-32 h-32 lg:w-40 lg:h-40 rounded-full bg-gradient-to-br from-amber/30 to-terracotta/20 mx-auto"></div>
          <div class="absolute top-4 left-4 w-24 h-24 lg:w-32 lg:h-32 rounded-full border-2 border-sage/30"></div>
        </div>
      </div>

      <!-- Blog card with toggle (right) -->
      <div class="md:col-span-3 md:col-start-10">
        <div class="rounded-xl border border-navy/10 bg-white/70 shadow-md backdrop-blur-sm px-4 py-4 flex flex-col gap-3 fade-up" id="blog-bar">
          <div class="flex items-center gap-1">
            <button
              type="button"
              id="tab-latest"
              class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full transition-colors bg-terracotta text-cream"
            >
              {t(lang, 'hero.latestPost')}
            </button>
            <button
              type="button"
              id="tab-discover"
              class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full transition-colors bg-transparent text-navy/50 hover:text-navy/70"
            >
              {t(lang, 'hero.discoverPosts')}
            </button>
          </div>
          <div id="panel-latest" class="flex flex-col gap-2">
            <LatestPostCard lang={lang} />
          </div>
          <div id="panel-discover" class="hidden flex-col gap-2">
            <DiscoverPostCard lang={lang} />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function wireHeroTabs() {
    const tabLatest = document.getElementById('tab-latest');
    const tabDiscover = document.getElementById('tab-discover');
    const panelLatest = document.getElementById('panel-latest');
    const panelDiscover = document.getElementById('panel-discover');
    if (!tabLatest || !tabDiscover || !panelLatest || !panelDiscover) return;
    if ((tabLatest as HTMLElement).dataset.wired === '1') return;
    (tabLatest as HTMLElement).dataset.wired = '1';

    function activate(tab: 'latest' | 'discover') {
      if (tab === 'latest') {
        panelLatest!.classList.remove('hidden');
        panelLatest!.classList.add('flex');
        panelDiscover!.classList.add('hidden');
        panelDiscover!.classList.remove('flex');
        tabLatest!.classList.add('bg-terracotta', 'text-cream');
        tabLatest!.classList.remove('bg-transparent', 'text-navy/50');
        tabDiscover!.classList.remove('bg-terracotta', 'text-cream');
        tabDiscover!.classList.add('bg-transparent', 'text-navy/50');
      } else {
        panelDiscover!.classList.remove('hidden');
        panelDiscover!.classList.add('flex');
        panelLatest!.classList.add('hidden');
        panelLatest!.classList.remove('flex');
        tabDiscover!.classList.add('bg-terracotta', 'text-cream');
        tabDiscover!.classList.remove('bg-transparent', 'text-navy/50');
        tabLatest!.classList.remove('bg-terracotta', 'text-cream');
        tabLatest!.classList.add('bg-transparent', 'text-navy/50');
      }
    }

    tabLatest.addEventListener('click', () => activate('latest'));
    tabDiscover.addEventListener('click', () => activate('discover'));
  }

  wireHeroTabs();
  document.addEventListener('astro:page-load', wireHeroTabs);
</script>

<script>
  import { gaEvent } from '../../lib/analytics';

  function wireCvDownload() {
    const cv = document.querySelector('[data-cv-download]');
    if (!cv || (cv as HTMLElement).dataset.wired === '1') return;
    (cv as HTMLElement).dataset.wired = '1';
    cv.addEventListener('click', () => gaEvent('download_cv', { source: 'hero' }));
  }

  wireCvDownload();
  document.addEventListener('astro:page-load', wireCvDownload);
</script>
