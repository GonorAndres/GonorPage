---
import type { Lang } from '../../i18n';

interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
  lang?: Lang;
  datePublished?: string;
  dateModified?: string;
  noindex?: boolean;
}

const siteUrl = 'https://gonor.me';
const {
  title,
  description,
  image = `${siteUrl}/og-default.png`,
  url = Astro.url.href,
  type = 'website',
  lang = 'es',
  datePublished,
  dateModified,
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(url, siteUrl).href;
const imageUrl = image.startsWith('http') ? image : new URL(image, siteUrl).href;

const AUTHOR_NAME = 'Andrés González Ortega';
const SAME_AS = [
  'https://github.com/GonorAndres',
  'https://www.linkedin.com/in/andr%C3%A9s-g%C3%B3nzalez-ortega-190b49371/',
];

// hreflang: derive the paired-language URL from the current path.
const path = new URL(canonicalUrl).pathname;
let esPath: string;
let enPath: string;
if (lang === 'en') {
  enPath = path;
  esPath = path.replace(/^\/en/, '') || '/';
} else {
  esPath = path;
  enPath = path === '/' ? '/en/' : `/en${path}`;
}
const esHref = new URL(esPath, siteUrl).href;
const enHref = new URL(enPath, siteUrl).href;

const person = {
  '@type': 'Person',
  name: AUTHOR_NAME,
  url: siteUrl,
};

const jsonLd = type === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      image: imageUrl,
      url: canonicalUrl,
      mainEntityOfPage: canonicalUrl,
      inLanguage: lang,
      ...(datePublished ? { datePublished } : {}),
      ...(dateModified ? { dateModified } : datePublished ? { dateModified: datePublished } : {}),
      author: person,
      publisher: person,
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: AUTHOR_NAME,
      url: siteUrl,
      jobTitle: lang === 'es' ? 'Actuario y Científico de Datos' : 'Actuary & Data Scientist',
      description,
      email: 'mailto:gonorandres@ciencias.unam.mx',
      knowsLanguage: ['es', 'en'],
      knowsAbout: [
        'Ciencia actuarial',
        'Solvencia II / LISF / CUSF',
        'Modelo Lee-Carter',
        'Machine Learning',
        'BigQuery',
        'Finanzas cuantitativas',
      ],
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'Universidad Nacional Autónoma de México',
        department: 'Facultad de Ciencias',
      },
      sameAs: SAME_AS,
    };
---

<meta name="description" content={description} />
{!noindex && <link rel="canonical" href={canonicalUrl} />}
{noindex && <meta name="robots" content="noindex, follow" />}

<!-- hreflang alternates -->
{!noindex && (
  <>
    <link rel="alternate" hreflang="es" href={esHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={esHref} />
  </>
)}

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={type} />
<meta property="og:locale" content={lang === 'es' ? 'es_MX' : 'en_US'} />
<meta property="og:site_name" content="Andrés González Ortega" />
{type === 'article' && datePublished && (
  <meta property="article:published_time" content={datePublished} />
)}
{type === 'article' && (dateModified || datePublished) && (
  <meta property="article:modified_time" content={dateModified ?? datePublished} />
)}
{type === 'article' && <meta property="article:author" content={AUTHOR_NAME} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
