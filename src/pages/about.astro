---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrganicBlob from '../components/decorations/OrganicBlob.astro';
import Squiggle from '../components/decorations/Squiggle.astro';

const lang = 'es';
const title = 'Sobre mí · Andrés González Ortega';
const description = 'Andrés González Ortega es un actuario formado en la Facultad de Ciencias de la UNAM que construye herramientas actuariales y de ciencia de datos en producción: tarificación GMM con datos CNSF, valuación de reservas bajo LISF y CUSF, agentes de IA sobre regulación mexicana y plataformas de datos en GCP.';

const email = 'gonorandres@ciencias.unam.mx';
const github = 'https://github.com/GonorAndres';
const linkedin = 'https://www.linkedin.com/in/andr%C3%A9s-g%C3%B3nzalez-ortega-190b49371/';

// Single source of truth per question: `a` is the third-person answer used in
// the FAQPage JSON-LD (search engines prefer full-name, self-contained
// answers); `visible` is the first-person text shown on the page. If
// `visible` is missing, `a` is shown.
const faqs = [
  {
    q: '¿Quién es Andrés González Ortega?',
    qVisible: '¿Quién soy?',
    a: 'Andrés González Ortega es un actuario formado en la Facultad de Ciencias de la UNAM que construye herramientas actuariales y de ciencia de datos en producción. Su trabajo combina la teoría del riesgo con software real: modelos de seguros, valuación de reservas, agentes de inteligencia artificial y plataformas de datos que resuelven problemas concretos del sector asegurador mexicano.',
    visible:
      'Soy actuario, formado en la Facultad de Ciencias de la UNAM. Me interesa el punto donde la teoría del riesgo se encuentra con el software: tomar un modelo que normalmente vive en un examen o en un paper y convertirlo en algo que alguien puede abrir en el navegador y usar. Casi todo lo que hay en este portafolio nació así, de querer ver funcionar algo que hasta entonces solo entendía en papel.',
  },
  {
    q: '¿Qué hace?',
    qVisible: '¿Qué hago?',
    a: 'Andrés González Ortega desarrolla software actuarial y analítico que llega a producción. Ha construido motores de tarificación de gastos médicos mayores con datos de la CNSF, sistemas de valuación de reservas bajo el marco de la LISF y la CUSF, agentes de IA que razonan sobre la regulación mexicana con recuperación aumentada (RAG) y plataformas de datos en la nube.',
    visible:
      'Construyo software actuarial y analítico, y lo llevo hasta producción. He armado un motor de tarificación de gastos médicos mayores con datos públicos de la CNSF, un sistema de valuación de reservas bajo la LISF y la CUSF, un agente de IA que responde preguntas sobre la regulación mexicana citando solo texto real de la ley, y plataformas de datos en la nube. No todos salieron a la primera; buena parte de lo que escribo en el blog es justamente qué falló y qué cambié.',
  },
  {
    q: '¿En qué tecnologías y áreas trabaja?',
    qVisible: '¿En qué tecnologías y áreas trabajo?',
    a: 'Andrés González Ortega trabaja entre la ciencia actuarial, el aprendizaje automático y la ingeniería de datos. En lo actuarial aplica modelos de riesgo, tarificación con modelos lineales generalizados, proyección de mortalidad con Lee-Carter y valuación de reservas bajo Solvencia II, la LISF y la CUSF. En lo técnico usa Python, plataformas de datos en Google Cloud como BigQuery y modelos de lenguaje con recuperación aumentada (RAG).',
    visible:
      'Me muevo entre lo actuarial y lo técnico. Del lado actuarial: modelos de riesgo, tarificación con modelos lineales generalizados, proyección de mortalidad con Lee-Carter y valuación de reservas bajo Solvencia II, la LISF y la CUSF. Del lado técnico: Python, Google Cloud (sobre todo BigQuery) y modelos de lenguaje con RAG. También hay experimentos que hice solo por curiosidad, como entrenar un transformer sobre la obra de Proust para entender los mecanismos de atención por dentro.',
  },
  {
    q: '¿Dónde estudió?',
    qVisible: '¿Dónde estudié?',
    a: 'Andrés González Ortega estudió la carrera de Actuaría en la Facultad de Ciencias de la Universidad Nacional Autónoma de México (UNAM) y se encuentra en proceso de titulación.',
    visible:
      'Estudié Actuaría en la Facultad de Ciencias de la UNAM y estoy en proceso de titulación. De ahí vienen las bases de probabilidad, estadística, finanzas y teoría del riesgo que sostienen todo lo demás.',
  },
  {
    q: '¿Cómo contactarlo?',
    qVisible: '¿Cómo contactarme?',
    a: `Puedes contactar a Andrés González Ortega por correo en ${email}. También está disponible en GitHub (${github}) y en LinkedIn (${linkedin}), donde publica su trabajo y proyectos.`,
    visible: `La forma más directa es el correo: ${email}. También publico mi trabajo en GitHub y LinkedIn.`,
    contact: true,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'es',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
};
---

<BaseLayout title={title} description={description} lang={lang}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <section class="relative overflow-hidden py-16 md:py-20 px-6">
    <OrganicBlob variant={1} color="#D4A574" class="w-[480px] h-[480px] -top-24 -right-32 opacity-40" />
    <OrganicBlob variant={3} color="#7A8B6F" class="w-[340px] h-[340px] bottom-10 -left-24 opacity-30" />

    <div class="max-w-3xl mx-auto relative z-10">
      <header class="mb-12">
        <p class="text-sage font-medium text-lg mb-2">Sobre mí</p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-navy leading-tight mb-4">
          Andrés González Ortega
        </h1>
        <p class="text-xl text-terracotta font-serif">
          Actuario y científico de datos · UNAM
        </p>
      </header>

      <Squiggle color="#C17654" class="w-full h-6 mb-12" />

      <div class="space-y-12">
        {faqs.map((f, i) => (
          <article class:list={['fade-up', i > 0 && 'pt-12 border-t border-navy/10']}>
            <h2 class="font-serif text-2xl md:text-3xl font-bold text-navy mb-4">
              {f.qVisible ?? f.q}
            </h2>
            <p class="text-navy/80 text-lg leading-relaxed">
              {f.visible ?? f.a}
            </p>
            {f.contact && (
              <div class="flex flex-wrap gap-3 mt-6">
                <a
                  href={`mailto:${email}`}
                  class="inline-block px-5 py-2.5 bg-terracotta text-cream font-medium rounded-xl hover:bg-terracotta/90 transition-colors"
                >
                  Correo
                </a>
                <a
                  href={github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block px-5 py-2.5 border-2 border-navy/20 text-navy font-medium rounded-xl hover:border-terracotta hover:text-terracotta transition-colors"
                >
                  GitHub
                </a>
                <a
                  href={linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block px-5 py-2.5 border-2 border-navy/20 text-navy font-medium rounded-xl hover:border-terracotta hover:text-terracotta transition-colors"
                >
                  LinkedIn
                </a>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
