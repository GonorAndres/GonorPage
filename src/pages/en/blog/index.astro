---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogSearch from '../../../components/ui/BlogSearch';
import { t } from '../../../i18n';
import { categories, categoryLabels, type Category } from '../../../data/categories';

const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === 'en')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const postsData = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  slug: post.id.replace(/^(es|en)\//, ''),
  date: post.data.date,
  lastModified: post.data.lastModified,
  categoryKey: post.data.category as Category,
  categoryLabel: categoryLabels['en'][post.data.category as Category] ?? post.data.category,
  tags: post.data.tags,
  lang: 'en' as const,
}));

const categoryCounts = categories
  .map((cat) => ({
    key: cat,
    label: categoryLabels['en'][cat],
    count: posts.filter((p) => p.data.category === cat).length,
  }))
  .filter((cc) => cc.count > 0);

const subtitle = 'Essays, analysis, and technical notes on actuarial science, quantitative finance, data, and tools.';

const labels = {
  searchPlaceholder: t('en', 'blog.searchPlaceholder'),
  noResults: t('en', 'blog.noResults'),
  articleSingular: t('en', 'blog.articleSingular'),
  articlePlural: t('en', 'blog.articlePlural'),
  readMore: t('en', 'blog.readMore'),
  sortRecent: 'Newest first',
  sortOldest: 'Oldest first',
  sortTitle: 'Title A–Z',
};
---

<BaseLayout title="Blog | Andrés González Ortega" description={subtitle} lang="en">
  <section class="py-10 sm:py-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_220px] gap-x-12 gap-y-6 items-end pb-6 mb-10 border-b border-[#1B2A4A]/15 fade-up"
      >
        <div>
          <h1
            class="font-serif text-3xl md:text-5xl font-semibold text-[#1B2A4A] leading-[1.05] tracking-tight"
          >
            {t('en', 'section.blog')}
          </h1>
          <p class="text-[#1B2A4A]/60 mt-3 max-w-[54ch]">{subtitle}</p>
        </div>
        <nav class="flex flex-col font-mono text-[10px] uppercase tracking-[0.12em]">
          <a
            href="/en/blog/"
            class="flex justify-between py-1.5 border-b border-[#1B2A4A] text-[#1B2A4A] no-underline"
          >
            <span>{t('en', 'blog.allPosts')}</span><span>{posts.length}</span>
          </a>
          {categoryCounts.map((cc) => (
            <a
              href={`/en/blog/categoria/${cc.key}/`}
              class="flex justify-between py-1.5 border-b border-[#1B2A4A]/15 text-[#1B2A4A]/55 hover:text-[#1B2A4A] no-underline transition-colors"
            >
              <span>{cc.label}</span><span>{cc.count}</span>
            </a>
          ))}
        </nav>
      </div>

      <BlogSearch client:idle posts={postsData} labels={labels} />
    </div>
  </section>
</BaseLayout>
